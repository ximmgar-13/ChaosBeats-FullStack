{
  "info": {
    "name": "Chaos Beats API",
    "description": "Colección de Postman para probar las Edge Functions de Chaos Beats",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "supabase_url",
      "value": "https://your-project.supabase.co"
    },
    {
      "key": "anon_key",
      "value": "your-anon-key"
    },
    {
      "key": "auth_token",
      "value": "your-jwt-token"
    }
  ],
  "item": [
    {
      "name": "Search Songs",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{auth_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"neon\",\n  \"genre\": \"electronic\",\n  \"limit\": 10,\n  \"offset\": 0\n}"
        },
        "url": {
          "raw": "{{supabase_url}}/functions/v1/search-songs",
          "host": ["{{supabase_url}}"],
          "path": ["functions", "v1", "search-songs"]
        }
      }
    },
    {
      "name": "Check Offline Access",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"offline-token-here\",\n  \"device_id\": \"device-uuid\",\n  \"song_ids\": [\"song-uuid-1\", \"song-uuid-2\"]\n}"
        },
        "url": {
          "raw": "{{supabase_url}}/functions/v1/check-offline-access",
          "host": ["{{supabase_url}}"],
          "path": ["functions", "v1", "check-offline-access"]
        }
      }
    },
    {
      "name": "App Version Check",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"platform\": \"android\",\n  \"current_version\": \"1.0.0\",\n  \"build_number\": 1\n}"
        },
        "url": {
          "raw": "{{supabase_url}}/functions/v1/app-version-check",
          "host": ["{{supabase_url}}"],
          "path": ["functions", "v1", "app-version-check"]
        }
      }
    },
    {
      "name": "Push Notification",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{auth_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"user-uuid\",\n  \"title\": \"New Song Available\",\n  \"body\": \"Your favorite artist just dropped a new track!\",\n  \"type\": \"new_song\",\n  \"data\": {\n    \"song_id\": \"song-uuid\",\n    \"artist_id\": \"artist-uuid\"\n  },\n  \"send_push\": true\n}"
        },
        "url": {
          "raw": "{{supabase_url}}/functions/v1/push-notification",
          "host": ["{{supabase_url}}"],
          "path": ["functions", "v1", "push-notification"]
        }
      }
    }
  ]
}
